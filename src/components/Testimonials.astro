---
const testimonials = [
  {
    text: "Luke's magic performances were absolutely captivating. The audience was mesmerized from start to finish. Highly professional and entertaining.",
    author: "Sarah Johnson",
    role: "Event Organizer"
  },
  {
    text: "One of the best close-up magicians I've ever seen. His technique is flawless and his stage presence is magnetic.",
    author: "Michael Chen",
    role: "Theater Manager"
  },
  {
    text: "Luke brought an incredible energy to our corporate event. Guests are still talking about his performances weeks later!",
    author: "Jennifer Martinez",
    role: "Corporate Events Coordinator"
  }
];
---

<div class="grid md:grid-cols-3 gap-6">
  {testimonials.map(testimonial => (
    <div class="card p-6 flex flex-col">
      <div class="flex gap-1 mb-4">
        {[...Array(5)].map(() => (
          <svg class="w-5 h-5 text-magic-gold" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
        ))}
      </div>
      <p class="flex-1 opacity-90 italic">"{testimonial.text}"</p>
      <div class="mt-4 pt-4 border-t border-neutral-700">
        <p class="font-serif font-bold">{testimonial.author}</p>
        <p class="text-sm text-magic-gold">{testimonial.role}</p>
      </div>
    </div>
  ))}
</div>
