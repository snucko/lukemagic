---
import Base from "../layouts/Base.astro";
---
<Base title="Page Not Found — Luke Magic" description="The page you're looking for doesn't exist.">
  <section class="max-w-6xl mx-auto px-6 py-32 text-center">
    <h1 class="text-6xl md:text-8xl font-serif font-bold leading-tight text-magic-purple">404</h1>
    <p class="mt-6 text-2xl md:text-3xl font-serif font-bold">The trick disappeared!</p>
    <p class="mt-4 text-lg opacity-90">The page you're looking for has vanished into thin air. Let's get you back on track.</p>
    
    <div class="mt-12 flex gap-4 justify-center flex-wrap">
      <a class="btn-primary" href="/">Return to Home</a>
      <a class="btn-ghost" href="/ideas/">Explore Tricks</a>
    </div>

    <div class="mt-20">
      <p class="text-sm opacity-60">Magic isn't about finding the answer—it's about enjoying the mystery.</p>
    </div>
  </section>
</Base>
