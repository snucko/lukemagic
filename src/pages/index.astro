---
import Base from "../layouts/Base.astro";
import Inspirations from "../components/Inspirations.astro";
import Testimonials from "../components/Testimonials.astro";
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const allIdeas = await getCollection('idea');
const latestTricks = allIdeas.slice(0, 3);
---
<Base title="Luke — Magic" description="Street magic, close-up, and stage by Luke.">
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div>
        <h1 class="text-4xl md:text-6xl font-serif font-bold leading-tight">Luke</h1>
        <p class="mt-4 text-lg opacity-90">Card and coin magic with impossible moments and clean endings.</p>
        <div class="mt-6 flex gap-3 flex-wrap">
          <a class="btn-primary" href="/ideas/">Explore Magic Tricks</a>
          <a class="btn-ghost" href="/shows/">Book a Performance</a>
        </div>
      </div>
      <img src="/media/gallery/row-1-column-1.png" alt="Luke performing magic" class="rounded-2xl transition-transform duration-300 hover:scale-105 w-full" loading="lazy" />
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-3xl md:text-4xl font-serif font-bold leading-tight">Latest Tricks</h2>
    <p class="mt-4 text-lg opacity-90">Discover new magic ideas added daily</p>
    <div class="grid md:grid-cols-3 gap-6 mt-10">
      {latestTricks.map(trick => (
        <div class="card p-6 hover:border-magic-purple transition-colors">
          <h3 class="text-xl font-bold font-serif">{trick.data.title}</h3>
          <p class="mt-3 opacity-80 text-sm">{trick.data.description}</p>
          <p class="mt-4 text-xs font-bold text-magic-gold uppercase">{trick.data.category}</p>
        </div>
      ))}
    </div>
    <div class="mt-8 text-center">
      <a class="btn-ghost" href="/ideas/">View All {allIdeas.length} Tricks →</a>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-3xl md:text-4xl font-serif font-bold leading-tight text-center">Featured Performance</h2>
    <p class="mt-4 text-lg opacity-90 text-center">Watch magic in action</p>
    <div class="mt-10 max-w-2xl mx-auto text-center">
      <a href="https://www.tiktok.com/@cequity/video/7561588816000175415" 
         target="_blank" 
         rel="noopener noreferrer"
         class="inline-flex items-center gap-2 btn-primary">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.1 1.82 2.9 2.9 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-.54-.05z"/>
        </svg>
        Watch on TikTok
      </a>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-3xl md:text-4xl font-serif font-bold leading-tight text-center">What People Say</h2>
    <p class="mt-4 text-lg opacity-90 text-center">Testimonials from clients and event organizers</p>
    <div class="mt-12">
      <Testimonials />
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-3xl md:text-4xl font-serif font-bold leading-tight text-center">Inspirations</h2>
    <p class="mt-4 text-lg opacity-90 text-center">A glimpse into the world of magic.</p>
    <Inspirations />
  </section>
</Base>